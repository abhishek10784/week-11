#include <stdio.h>
struct Student
{
  	char name[50];
  	int roll;
  	float gpa;
};
int main()
{
  	printf("25331A05H2");
  	int n, i;
  	printf("Enter number of students: ");
  	scanf("%d", &n);
  	struct Student s[n];
  	for (i = 0; i < n; i++)
  	{
        	printf("Enter name, roll, GPA: ");
        	scanf("%s %d %f", s[i].name, &s[i].roll, &s[i].gpa);
  	}
  	printf("\n--- Student Records ---\n");
  	for (i = 0; i < n; i++)
  	{
        	printf("%s | Roll: %d | GPA: %.2f\n", s[i].name, s[i].roll, s[i].gpa);
  	}
  	return 0;
}
